    create or replace table `evocative-depot-427007-m8`.`online_ecommerce_star_schema_marts`.`fct_customer_sessions`
      
    
    

    OPTIONS()
    as (
      

with events as (
    select * from `evocative-depot-427007-m8`.`online_ecommerce_star_schema_staging`.`stg_events`
),

session_aggregation as (
    select
        session_id,
        
        -- Pull out the customer ID if they ever log in or checkout during this specific session
        max(case when event_type in ('login', 'checkout', 'purchase') and customer_id is not null then customer_id else null end) as contextual_customer_id,
        
        -- Core timeline boundaries
        min(event_timestamp) as session_started_at,
        max(event_timestamp) as session_ended_at,
        
        -- Interaction volume metrics
        count(event_id) as total_interactions,
        count(case when event_type = 'page_view' then event_id end) as page_view_count,
        
        -- Dynamic e-commerce conversion funnel flags
        max(case when event_type = 'product_view' then 1 else 0 end) as flag_viewed_product,
        max(case when event_type = 'add_to_cart' then 1 else 0 end) as flag_added_to_cart,
        max(case when event_type = 'checkout' then 1 else 0 end) as flag_initiated_checkout,
        max(case when event_type = 'purchase' then 1 else 0 end) as flag_completed_purchase,
        
        -- Financial extraction from the purchase event
        max(case when event_type = 'purchase' then amount_usd else 0.0 end) as total_session_purchase_amount_usd
        
    from events
    group by 1
)

select
    -- 1. Unique Surrogate Primary Key
    to_hex(md5(session_id)) as session_key,
    session_id,
    
    -- 2. Star Schema Dimension References
    coalesce(contextual_customer_id, 'anonymous_guest') as customer_id,
    cast(session_started_at as date) as session_date,
    
    -- 3. Temporal Session Durations
    session_started_at,
    session_ended_at,
    timestamp_diff(session_ended_at, session_started_at, second) as session_duration_seconds,
    
    -- 4. Behavior Volume Facts
    total_interactions,
    page_view_count,
    
    -- 5. Funnel Boolean Outputs
    cast(flag_viewed_product as boolean) as has_viewed_product,
    cast(flag_added_to_cart as boolean) as has_added_to_cart,
    cast(flag_initiated_checkout as boolean) as has_initiated_checkout,
    cast(flag_completed_purchase as boolean) as is_converted_purchase,
    
    -- 6. Actionable Revenue Metrics
    total_session_purchase_amount_usd,
    
    -- 7. High-Value Advanced Portfolio Metrics
    case 
        when flag_added_to_cart = 1 and flag_completed_purchase = 0 then true 
        else false 
    end as is_abandoned_cart,
    
    case
        when timestamp_diff(session_ended_at, session_started_at, second) < 10 and total_interactions = 1 then true
        else false
    end as is_bounced_session

from session_aggregation
    );
  
