  create or replace view `evocative-depot-427007-m8`.`online_ecommerce_star_schema_staging`.`stg_events`
  OPTIONS()
  as with source as (
    select * from `evocative-depot-427007-m8`.`online_ecommerce_star_schema_raw`.`raw_events`
)

select
    cast(event_id as string) as event_id,
    cast(session_id as string) as session_id,
    cast(event_type as string) as event_type,
    
    --force fix to proper timestamp format (remove the 'T')
    coalesce(
        safe_cast(timestamp as timestamp),
        parse_timestamp('%Y-%m-%dT%H:%M:%E*S', timestamp)
    ) as event_timestamp,

    product_id, 
    qty,
    cart_size,
    payment,
    discount_pct,
    amount_usd

from source;


